# ── Database ──────────────────────────────────────────────────────────────
# Railway PostgreSQL connection string (set automatically in Railway)
DATABASE_URL="postgresql://user:password@host:5432/teambase"

# ── Auth (Better Auth) ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="your-32-byte-secret-here"
BETTER_AUTH_URL="https://your-domain.up.railway.app"
# Restrict signups/logins to this email domain
ALLOWED_EMAIL_DOMAIN="yourdomain.com"

# ── Airtable ──────────────────────────────────────────────────────────────
AIRTABLE_API_KEY="patXXXXXXXXXXXXXX"
AIRTABLE_BASE_ID="appXXXXXXXXXXXXXX"

# ── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY="re_XXXXXXXXXXXX"
EMAIL_FROM="TeamBase <no-reply@yourdomain.com>"

# ── Airtable sync secret (generate with: openssl rand -hex 16) ────────────
SYNC_SECRET="your-sync-secret"

# ── Monitoring (Sentry) — optional ───────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ── Rate limiting (Upstash Redis) — optional ─────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Public ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-domain.up.railway.app"
